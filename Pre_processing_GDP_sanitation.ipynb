import os
import rasterio
import numpy as np
import pandas as pd
import yaml
import time
import dask.array as da
from dask.diagnostics import ProgressBar
from rasterio.vrt import WarpedVRT
from rasterio.windows import from_bounds
from dask.distributed import Client
import psutil

# ✅ Kill Old Dask Processes (Prevents Stuck Kernels)
def kill_existing_dask():
    """ Kill any running Dask processes to prevent conflicts. """
    for proc in psutil.process_iter(attrs=["pid", "name"]):
        if "dask" in proc.info["name"].lower() or "python" in proc.info["name"].lower():
            try:
                os.kill(proc.info["pid"], 9)
            except:
                pass

kill_existing_dask()

# ✅ Step 1: Define Flexible Directories
input_dir = r"N:\Projects\11211000\11211459\F. Other information\003 Floods and Health"
output_dir = r"N:\Projects\11211000\11211459\F. Other information\003 Floods and Health\output"

# Ensure output directory exists
os.makedirs(output_dir, exist_ok=True)

# 📂 Step 2: Define Input File Paths
population_raster = os.path.join(input_dir, "moz_population_combined_compressed.tif")
urban_rural_raster = os.path.join(input_dir, "Urban_rural_classification.tif")
sanitation_file = os.path.join(input_dir, "sanitation_data.xlsx")
gdp_file = os.path.join(input_dir, "gdp_data.yaml")
output_raster = os.path.join(output_dir, "ecoli_emissions.tif")

# ✅ Step 3: Validate Input Files Exist
for file_path in [population_raster, urban_rural_raster, sanitation_file, gdp_file]:
    if not os.path.exists(file_path):
        raise FileNotFoundError(f"⚠️ Required file not found: {file_path}")

# 📌 Standard E. coli Emission Per Person (CFU/100mL)
ECOLI_PER_PERSON = 1e9  

# ✅ Step 4: Start Dask Cluster (Optimized for Memory)
client = Client(processes=True, threads_per_worker=1, n_workers=3, memory_limit="16GB")
print(client)

# 🌍 Load GDP Data & Compute Weight Factor (WF)
with open(gdp_file, "r") as file:
    gdp_data = yaml.safe_load(file)

country_name = input("Enter the country name: ")
gdp_per_capita = gdp_data["countries"].get(country_name, {}).get("GDP_per_capita", None)
if gdp_per_capita is None:
    raise ValueError(f"⚠️ GDP data not found for {country_name}")

weight_factor = max(0.5, (1 - (gdp_per_capita / 80)))

# 📊 Load Sanitation Data
sanitation_df = pd.read_excel(sanitation_file)
sanitation_data = sanitation_df[sanitation_df["country"] == country_name]
if sanitation_data.empty:
    raise ValueError(f"⚠️ Sanitation data not found for {country_name}")

# Convert sanitation data to NumPy
sanitation_types = ["Safe", "Advanced", "Basic", "None"]
urban_reduction_factors = np.array([
    sanitation_data[sanitation_data["sanitation_type"] == st]["urban_reduction_factor"].values[0] 
    for st in sanitation_types
])
rural_reduction_factors = np.array([
    sanitation_data[sanitation_data["sanitation_type"] == st]["rural_reduction_factor"].values[0] 
    for st in sanitation_types
])
urban_coverage = np.array([
    sanitation_data[sanitation_data["sanitation_type"] == st]["urban_coverage (%)"].values[0] / 100 
    for st in sanitation_types
])
rural_coverage = np.array([
    sanitation_data[sanitation_data["sanitation_type"] == st]["rural_coverage (%)"].values[0] / 100 
    for st in sanitation_types
])

# Compute sanitation factors
urban_sanitation_factor = np.dot(urban_reduction_factors, urban_coverage)
rural_sanitation_factor = np.dot(rural_reduction_factors, rural_coverage)

start_time = time.time()

# 📌 Load Population Raster & Get Extent
with rasterio.open(population_raster) as pop_src:
    pop_transform = pop_src.transform
    profile = pop_src.profile  
    pop_bounds = pop_src.bounds  

# 📌 Use Warped VRT for Faster Urban-Rural Clipping
with rasterio.open(urban_rural_raster) as urb_src:
    with WarpedVRT(urb_src) as vrt:
        urb_window = from_bounds(*pop_bounds, vrt.transform)
        urban_rural = vrt.read(window=urb_window).astype(np.int8)  

# 🔹 Create Urban/Rural Masks
urban_mask = da.from_array(urban_rural[0] == 1, chunks=(64, 64))
rural_mask = da.from_array(urban_rural[1] == 2, chunks=(64, 64))

# 📌 Load Population Raster in Chunks
with rasterio.open(population_raster) as pop_src:
    population = da.from_array(pop_src.read(3), chunks=(64, 64)).astype(np.float64)

# 🚀 Run Processing
def compute_emissions(pop_chunk, urban_chunk, rural_chunk):
    sanitation_factor = da.ones_like(pop_chunk, dtype=np.float64)  
    sanitation_factor[urban_chunk] = urban_sanitation_factor
    sanitation_factor[rural_chunk] = rural_sanitation_factor

    return pop_chunk * ECOLI_PER_PERSON * sanitation_factor * weight_factor

emissions = da.map_blocks(compute_emissions, population, urban_mask, rural_mask)

# ✅ Step 5: Execute & Monitor Performance
with ProgressBar():
    emissions = emissions.persist()
    emissions = emissions.compute()

end_time = time.time()
print(f"✅ Processing completed in {end_time - start_time:.2f} seconds.")

# 🗺️ Save Output as GeoTIFF
profile.update(dtype=rasterio.float64, count=1)

with rasterio.open(output_raster, "w", **profile) as dst:
    dst.write(emissions, 1)

print(f"✅ E. coli Emission Map saved at: {output_raster}")